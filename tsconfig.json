{
	"compilerOptions": {
		"module": "commonjs",
		"target": "ES2020",
		"outDir": "out",
		"lib": [
			"ES2020"
		],
		"sourceMap": true,
		"rootDir": "src",
		"strict": false, // Disable all strict type-checking compiler options
		"noImplicitAny": false, // added so error/warning: Parameter 'xxx' implicitly has an 'any' type is removed.
	}
}